# ─────────────────────────────────────────────────────────────────────────────
# Liafon Stock Management — Environment Configuration
# Copy this file to `.env` and update the values as needed.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Database ─────────────────────────────────────────────────────────────────
# The Prisma schema (prisma/schema.prisma) is PostgreSQL-only.
# You need a Supabase project (free tier is fine): https://supabase.com
#
# LOCAL DEV (Supabase free tier works for local dev too — same connection strings):
#  1. Create a project at https://supabase.com
#  2. Go to: Project Settings → Database → Connection string
#  3. Copy TWO connection strings:
#       - "Transaction pooler" (port 6543) → DATABASE_URL
#       - "Direct connection"  (port 5432) → DIRECT_URL
#
# DATABASE_URL  → used by the runtime Prisma client (port 6543 + PgBouncer).
#                 MUST include ?pgbouncer=true&connection_limit=1&prepare=false
#                 so each Vercel serverless function shares a pooled connection
#                 instead of opening its own (which would crash Supabase).
#                 The app auto-appends these params if you forget them — but
#                 you should set them explicitly to silence the log warning.
#
# DIRECT_URL    → used ONLY by `prisma migrate deploy` / `prisma db push` at
#                 build time. MUST be a direct Postgres connection (port 5432,
#                 NO pgbouncer=true). Migrations don't work through PgBouncer.
#
# Example values (replace PASSWORD, xxxxxx, and region):
#
DATABASE_URL=postgresql://postgres.xxxxxx:PASSWORD@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&prepare=false
DIRECT_URL=postgresql://postgres.xxxxxx:PASSWORD@aws-0-ap-south-1.pooler.supabase.com:5432/postgres

# NOTE: The legacy SQLite default (DATABASE_URL=file:./data/liafon.db) has been
# removed — the Prisma schema is postgresql-only. If you need SQLite for
# offline local dev, you'd have to make the schema provider env-driven, which
# is out of scope for this Vercel + Supabase deployment.

# Application
APP_NAME=Liafon Stock Management
# NOTE: The legacy APP_PASSWORD / "developer unlock" endpoint has been
# removed. It set a `liafon_dev=1` cookie that was never checked anywhere
# else in the codebase, so it was either dead code or a latent backdoor.
# If you previously relied on it, use LIAFON_DEV_KEY (below) instead.

# ─── Backup Settings ────────────────────────────────────────────────────────
# Directory where JSON + Excel backups are written.
#
# IMPORTANT FOR VERCEL: Vercel's filesystem is READ-ONLY except for /tmp.
# The backup route automatically falls back to /tmp/liafon-backups on Vercel.
# This means backups are EPHEMERAL — they vanish when the serverless
# function's container is recycled. Download backups immediately after
# creating them, OR integrate with Supabase Storage / Vercel Blob for
# persistent backups (TODO: not yet implemented).
#
# For self-hosted (node server.js), this is honored as-is.
BACKUP_DIR=./backups
# Hour of the day (0-23, local time) at which the daily auto-backup runs.
# Backups missed while the system was off are triggered on the next startup.
DAILY_BACKUP_HOUR=23

# ─── Currency ──────────────────────────────────────────────────────────────
# Default currency for new parts. Available: INR, USD, EUR, GBP, AED, SAR,
# JPY, CNY, KWD, QAR, OMR, BHD, PKR, BDT, LKR, NPR, MYR, SGD, THB, AUD.
DEFAULT_CURRENCY=INR

# ─── WhatsApp Integration (optional) ───────────────────────────────────────
# To send WhatsApp messages automatically (instead of opening wa.me links),
# run an OpenWA server (https://github.com/openwa/openwa) and set the URL +
# API key below. If left blank, the app falls back to wa.me deep links.
OPENWA_API_URL=
OPENWA_API_KEY=
OPENWA_SESSION=default

# ─── Email (Gmail) for Password Reset ─────────────────────────────────────
# To enable email-based password reset:
#   1. Enable 2-Step Verification on your Gmail account
#   2. Generate an App Password at https://myaccount.google.com/apppasswords
#   3. Set GMAIL_USER and GMAIL_APP_PASSWORD below
#   4. Set APP_BASE_URL to the URL users will click (e.g. https://yourapp.vercel.app)
# If these are NOT set, password reset falls back to dev mode (shows the
# reset link directly in the UI instead of emailing it).
GMAIL_USER=
GMAIL_APP_PASSWORD=
# IMPORTANT FOR VERCEL: Set this to your production URL (e.g. https://liafon.vercel.app),
# NOT localhost. Otherwise the password-reset email link will be broken.
APP_BASE_URL=http://localhost:3000

# ─── Security ──────────────────────────────────────────────────────────────
# Set to "production" to enable Secure cookies and stricter logging.
NODE_ENV=development

# Pepper for tamper-evident activity log hashes (SHA-256)
# Generate: openssl rand -hex 32
ACTIVITY_LOG_PEPPER=

# Pepper for IP-based duplicate account detection (SHA-256 hash of IP)
# Prevents users from creating multiple owner accounts from the same IP
# Generate: openssl rand -hex 32
REGISTRATION_PEPPER=

# Max owner accounts allowed per IP (default: 1)
MAX_OWNERS_PER_IP=1

# ─── Server (self-hosted only — ignored on Vercel) ─────────────────────────
# Port the standalone server listens on.
PORT=3000
HOSTNAME=0.0.0.0

# ─── Developer License Key ─────────────────────────────────────────────────
# This key is used by the developer to activate/deactivate licenses via
# POST /api/license. The owner CANNOT change this from the UI — only
# the developer can.
#
# SECURITY: Generate a strong random value (min 16 chars). Previously
# this defaulted to a hardcoded 'liafon-dev-master-2024' that anyone
# reading the source could use to deactivate the app. The /api/license
# POST endpoint now refuses to operate if LIAFON_DEV_KEY is unset or
# shorter than 16 chars.
#
# Generate one with:  openssl rand -hex 32
LIAFON_DEV_KEY=

# ─── Cloud License Server (Optional) ───────────────────────────────────────
# If set, the app checks this URL every 5 minutes to validate the license.
# If the cloud says "inactive", the app locks (even if local license is active).
# If the cloud is unreachable, the app falls back to local license status.
# See DEVELOPER/CLOUD-LICENSE-SETUP.md for setup instructions.
CLOUD_LICENSE_URL=
CLOUD_LICENSE_KEY=

# ─── Vercel-only: Maximum upload size for /api/import (in MB) ───────────────
# Vercel Hobby plan caps request body at 4.5 MB; Pro plan allows up to 50 MB.
# Make sure this value is at or below your plan's limit.
IMPORT_MAX_MB=5

# ─── Supabase Storage (for persistent backups on Vercel) ───────────────────
# Vercel's filesystem is read-only except /tmp, and /tmp is wiped on cold starts.
# To make backups persist, upload them to a Supabase Storage bucket.
#
# Setup:
#   1. In your Supabase project: Storage → New bucket
#      - Name: liafon-backups (or whatever you set below)
#      - Public: NO (these contain customer data!)
#   2. Project Settings → API → copy the "service_role" key
#   3. Set the three vars below in Vercel
#
# The service_role key bypasses RLS — required because the API runs server-side.
# NEVER expose this key to the client.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET_NAME=liafon-backups

# ─── Upstash Redis (for distributed rate limiting on Vercel) ───────────────
# Vercel serverless is stateless — each instance has its own in-memory rate
# limit counter, so an attacker can bypass limits by triggering cold starts.
# Upstash Redis is the recommended cross-instance limiter for Vercel.
#
# Setup:
#   1. Create a free Upstash Redis database: https://upstash.com
#   2. Copy the REST URL + token from the database dashboard
#   3. Set both vars below in Vercel
#
# If NOT set, the app falls back to the in-memory limiter (works locally
# but is bypassable in production).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── SMTP (any provider — Outlook, SendGrid, SES, Mailgun, etc.) ───────────
# The email service supports BOTH Gmail (legacy, see GMAIL_* vars above)
# AND generic SMTP. SMTP_* vars take precedence when both are set.
#
# Common providers:
#   - Outlook:    smtp.office365.com:587 (SMTP_SECURE=false)
#   - SendGrid:   smtp.sendgrid.net:587  (SMTP_USER=apikey, SMTP_PASS=SG.xxxx)
#   - Amazon SES: email-smtp.us-east-1.amazonaws.com:587
#   - Mailgun:    smtp.mailgun.org:587
#   - Zoho Mail:  smtp.zoho.com:465      (SMTP_SECURE=true)
#
# SMTP_FROM is optional — defaults to SMTP_USER if not set.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_SECURE=false

# ─── Audit Log Retention (auto-cleanup old activity logs) ──────────────────
# Logs older than this many days are auto-deleted by the daily cron.
# Set to 0 to disable retention (keep forever — NOT recommended for free tier).
# Default: 365 days.
AUDIT_RETENTION_DAYS=365

# ─── Expiry Alert Window (near-expiry WhatsApp digest) ─────────────────────
# Batches expiring within this many days trigger a WhatsApp/email alert
# via the daily cron. Default: 30 days.
EXPIRY_ALERT_DAYS=30

# ─── Shop UPI VPA (for QR generation in Sales page) ────────────────────────
# The shop's UPI VPA — used by the UpiPaymentModal to generate collect QRs.
# Format: name@bank (e.g. "merchant@okhdfcbank")
# If not set, the UPI button in the Sales page will show a warning.
NEXT_PUBLIC_SHOP_UPI_VPA=
NEXT_PUBLIC_SHOP_NAME=Liafon Stock Management

# ─── Vercel Cron Secret ────────────────────────────────────────────────────
# Protects the /api/cron/backup endpoint. Vercel Cron Jobs can pass this
# as ?secret=<value>. Generate a strong random value:
#   openssl rand -hex 32
#
# Then add the same value to your Vercel Cron Job config (or pass it via
# the Vercel dashboard when setting up the cron).
CRON_SECRET=

# ─── Free WhatsApp via Baileys (no paid Twilio) ────────────────────────────
# Two deployment modes:
#
# Mode A (self-hosted / VPS): Leave BAILEYS_SERVER_URL empty. The app
#   runs Baileys in-process. Pair by scanning QR code at /api/whatsapp/baileys/status.
#
# Mode B (Vercel): Vercel serverless can't hold a persistent WhatsApp Web
#   WebSocket. Run a separate small Baileys "gateway" process on a free
#   Railway/Render/VPS instance (see scripts/baileys-server.js — included).
#   Set BAILEYS_SERVER_URL to that server's URL + a shared API key.
#
# Why Baileys? It's the only production-grade open-source WhatsApp library
# (MIT license). No per-message fees. Repo: https://github.com/WhiskeySockets/Baileys
BAILEYS_SERVER_URL=
BAILEYS_API_KEY=

# ─── Free Voice calls via FreeSWITCH/Asterisk (no paid Twilio) ─────────────
# Voice calls route through a self-hosted FreeSWITCH (MIT) or Asterisk (GPL)
# voice gateway. The gateway code is in scripts/voice-gateway.js.
#
# If not set, /api/voice/call returns a `tel:` deep link (opens phone dialer).
#
# For video calls, we use Jitsi Meet (Apache 2.0, free public instance).
# Set JITSI_SERVER_URL only if you're self-hosting Jitsi.
VOICE_GATEWAY_URL=
VOICE_GATEWAY_API_KEY=
JITSI_SERVER_URL=https://meet.jit.si


