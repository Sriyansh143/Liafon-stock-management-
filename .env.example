# ─────────────────────────────────────────────────────────────────────────────
# Liafon Stock Management — Environment Configuration
# ─────────────────────────────────────────────────────────────────────────────

# ─── Database ─────────────────────────────────────────────────────────────────
# IMPORTANT: For the Supabase Connection Pooler, the username MUST include 
# your project reference ID (e.g., postgres.<project-ref>).
# Your project ref is: npssvsafswkwbstbvrii
#
# DATABASE_URL  → used by the runtime Prisma client (Transaction pooler, port 6543).
# DIRECT_URL    → used ONLY by `prisma migrate deploy` / `prisma db push` (Direct, port 5432).
#
DATABASE_URL="postgresql://postgres.npssvsafswkwbstbvrii:Sriyanshabhimanyu1%40%40.@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&prepare=false"
DIRECT_URL="postgresql://postgres:Sriyanshabhimanyu1%40%40.@db.npssvsafswkwbstbvrii.supabase.co:5432/postgres"

# Application
APP_NAME=Liafon Stock Management

# ─── Backup Settings ────────────────────────────────────────────────────────
BACKUP_DIR=./backups
DAILY_BACKUP_HOUR=23

# ─── Currency ──────────────────────────────────────────────────────────────
DEFAULT_CURRENCY=INR

# ─── WhatsApp Integration (optional) ───────────────────────────────────────
OPENWA_API_URL=
OPENWA_API_KEY=
OPENWA_SESSION=default

# ─── Email (Gmail) for Password Reset ─────────────────────────────────────
GMAIL_USER=
GMAIL_APP_PASSWORD=
APP_BASE_URL=http://localhost:3000

# ─── Security ──────────────────────────────────────────────────────────────
NODE_ENV=development
ACTIVITY_LOG_PEPPER=
REGISTRATION_PEPPER=
MAX_OWNERS_PER_IP=1

# ─── Server (self-hosted only — ignored on Vercel) ─────────────────────────
PORT=3000
HOSTNAME=0.0.0.0

# ─── Developer License Key ─────────────────────────────────────────────────
LIAFON_DEV_KEY=

# ─── Cloud License Server (Optional) ───────────────────────────────────────
CLOUD_LICENSE_URL=
CLOUD_LICENSE_KEY=

# ─── Vercel-only: Maximum upload size for /api/import (in MB) ───────────────
IMPORT_MAX_MB=5

# ─── Supabase Storage (for persistent backups on Vercel) ───────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET_NAME=liafon-backups

# ─── Upstash Redis (for distributed rate limiting on Vercel) ───────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── SMTP (any provider — Outlook, SendGrid, SES, Mailgun, etc.) ───────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_SECURE=false

# ─── Audit Log Retention (auto-cleanup old activity logs) ──────────────────
AUDIT_RETENTION_DAYS=365

# ─── Expiry Alert Window (near-expiry WhatsApp digest) ─────────────────────
EXPIRY_ALERT_DAYS=30

# ─── Shop UPI VPA (for QR generation in Sales page) ────────────────────────
NEXT_PUBLIC_SHOP_UPI_VPA=
NEXT_PUBLIC_SHOP_NAME=Liafon Stock Management

# ─── Vercel Cron Secret ────────────────────────────────────────────────────
CRON_SECRET=

# ─── Free WhatsApp via Baileys (no paid Twilio) ────────────────────────────
BAILEYS_SERVER_URL=
BAILEYS_API_KEY=

# ─── Free Voice calls via FreeSWITCH/Asterisk (no paid Twilio) ─────────────
VOICE_GATEWAY_URL=
VOICE_GATEWAY_API_KEY=
JITSI_SERVER_URL=https://meet.jit.si