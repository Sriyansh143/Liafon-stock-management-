generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Multi-Tenant Models ────────────────────────────────────────────────────

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  password      String
  role          String   @default("user")
  isActive      Boolean  @default(true)
  lastLogin     DateTime?
  passwordChangedAt DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  ownerId       String   @default("")
  ipHash        String?
  twoFactorEnabled Boolean @default(false)
  twoFactorSecret  String?
  shopId        String?
  shop          Shop?    @relation(fields: [shopId], references: [id])
  activityLogs  ActivityLog[]
  @@index([ownerId])
  @@index([email])
  @@index([ipHash])
  @@index([shopId])
}

model License {
  id           String   @id @default(cuid())
  ownerId      String   @unique
  licenseKey   String   @unique
  customerName String   @default("")
  status       String   @default("trial")
  createdAt    DateTime @default(now())
  activatedAt  DateTime @default(now())
  expiresAt    DateTime
  paymentStatus String  @default("pending")
  amount       Float    @default(4999)
  currency     String   @default("INR")
  ip           String   @default("")
  metadata     String   @default("{}")
  plan         String   @default("free")
  @@index([ownerId])
  @@index([licenseKey])
  @@index([status])
}

model Shop {
  id           String   @id @default(cuid())
  ownerId      String   @default("")
  name         String
  address      String   @default("")
  city         String   @default("")
  state        String   @default("")
  pincode      String   @default("")
  phone        String   @default("")
  email        String   @default("")
  gstin        String   @default("")
  latitude     Float?
  longitude    Float?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  users        User[]
  spareParts   SparePart[]
  sales        Sale[]
  purchases    Purchase[]
  stockLogs    StockLog[]
  customers    Customer[]
  suppliers    Supplier[]
  purchaseOrders PurchaseOrder[]
  transfersFrom StockTransfer[] @relation("StockTransfer_FromShop")
  transfersTo   StockTransfer[] @relation("StockTransfer_ToShop")
  @@unique([ownerId, name])
  @@index([ownerId])
  @@index([state])
}

model SparePart {
  id            String   @id @default(cuid())
  ownerId       String   @default("")
  shopId        String?
  shop          Shop?    @relation(fields: [shopId], references: [id])
  partNumber    String
  name          String
  category      String
  brand         String
  vehicleModel  String
  description   String   @default("")
  costPrice     Float
  sellingPrice  Float
  currentStock  Int      @default(0)
  minStockLevel Int      @default(5)
  location      String   @default("")
  isActive      Boolean  @default(true)
  currency      String   @default("INR")
  barcode       String   @default("")
  imageUrl      String   @default("")
  baseUom                  String   @default("PCS")
  purchaseUom              String   @default("PCS")
  purchaseToBaseConversion Float    @default(1)
  sellingUom               String   @default("PCS")
  sellingToBaseConversion  Float    @default(1)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  sales     Sale[]
  purchases Purchase[]
  stockLogs StockLog[]
  batches   Batch[]
  transfersFrom StockTransfer[] @relation("StockTransfer_FromPart")
  transfersTo   StockTransfer[] @relation("StockTransfer_ToPart")
  alternativesFrom PartAlternative[] @relation("PartAlternative_From")
  alternativesTo   PartAlternative[] @relation("PartAlternative_To")
  metaValues      PartMeta[]
  stockCountItems StockCountItem[]
  reservations    StockReservation[]
  @@unique([ownerId, partNumber])
  @@index([ownerId])
  @@index([ownerId, category])
  @@index([shopId])
}

model Batch {
  id            String   @id @default(cuid())
  ownerId       String   @default("")
  partId        String
  part          SparePart @relation(fields: [partId], references: [id])
  batchNumber   String   @default("")
  serialNumber  String   @default("")
  quantity      Int      @default(0)
  expiryDate    DateTime?
  manufactureDate DateTime?
  unitCost      Float    @default(0)
  supplierId    String?
  supplier      Supplier? @relation(fields: [supplierId], references: [id])
  purchaseOrderId String?
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  @@index([ownerId])
  @@index([partId])
  @@index([expiryDate])
  @@index([serialNumber])
}

model Department {
  id        String   @id @default(cuid())
  ownerId   String   @default("")
  name      String
  phone     String
  role      String   @default("general")
  email     String   @default("")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([ownerId])
}

model Customer {
  id        String   @id @default(cuid())
  ownerId   String   @default("")
  shopId    String?
  shop      Shop?    @relation(fields: [shopId], references: [id])
  name      String
  phone     String   @default("")
  email     String   @default("")
  address   String   @default("")
  notes     String   @default("")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  sales Sale[]
  payments Payment[]
  creditLimit Float  @default(0)
  gstNumber  String  @default("")
  state      String  @default("")
  @@index([ownerId])
  @@index([shopId])
  @@index([gstNumber])
}

model Supplier {
  id        String   @id @default(cuid())
  ownerId   String   @default("")
  shopId    String?
  shop      Shop?    @relation(fields: [shopId], references: [id])
  name      String
  phone     String   @default("")
  email     String   @default("")
  address   String   @default("")
  gstNumber String   @default("")
  notes     String   @default("")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  purchases Purchase[]
  batches   Batch[]
  purchaseOrders PurchaseOrder[]
  @@index([ownerId])
  @@index([shopId])
}

model Sale {
  id           String   @id @default(cuid())
  ownerId      String   @default("")
  shopId       String?
  shop         Shop?    @relation(fields: [shopId], references: [id])
  partId       String
  part         SparePart @relation(fields: [partId], references: [id])
  quantity     Int
  unitPrice    Float
  totalPrice   Float
  customerName String
  customerPhone String  @default("")
  notes        String   @default("")
  currency     String   @default("INR")
  invoiceNumber String  @default("")
  date         DateTime @default(now())
  createdAt    DateTime @default(now())
  customer Customer? @relation(fields: [customerId], references: [id])
  customerId String?
  taxRate      Float    @default(0)
  cgstRate     Float    @default(0)
  cgstAmount   Float    @default(0)
  sgstRate     Float    @default(0)
  sgstAmount   Float    @default(0)
  igstRate     Float    @default(0)
  igstAmount   Float    @default(0)
  taxableValue Float    @default(0)
  discount       Float   @default(0)
  discountType   String  @default("flat")
  discountAmount Float   @default(0)
  hsnCode        String  @default("")
  amountPaid   Float    @default(0)
  paymentStatus String  @default("paid")
  payments     Payment[]
  returns      SaleReturn[]
  @@index([ownerId])
  @@index([ownerId, date])
  @@index([partId])
  @@index([invoiceNumber])
  @@index([paymentStatus])
}

model Payment {
  id            String   @id @default(cuid())
  ownerId       String   @default("")
  saleId        String?
  sale          Sale?    @relation(fields: [saleId], references: [id])
  customerId    String?
  customer      Customer? @relation(fields: [customerId], references: [id])
  amount        Float
  method        String   @default("cash")
  reference     String   @default("")
  notes         String   @default("")
  date          DateTime @default(now())
  createdAt     DateTime @default(now())
  upiVpa        String   @default("")
  upiPhone      String   @default("")
  upiQrScanned  Boolean  @default(false)
  upiQrImage    String   @default("")
  @@index([ownerId])
  @@index([saleId])
  @@index([customerId])
  @@index([date])
  @@index([method])
}

model TaxRate {
  id          String   @id @default(cuid())
  ownerId     String   @default("")
  category    String
  rate        Float    @default(0)
  hsnCode     String   @default("")
  description String   @default("")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@unique([ownerId, category])
  @@index([ownerId])
}

model Purchase {
  id           String   @id @default(cuid())
  ownerId      String   @default("")
  shopId       String?
  shop         Shop?    @relation(fields: [shopId], references: [id])
  partId       String
  part         SparePart @relation(fields: [partId], references: [id])
  quantity     Int
  unitCost     Float
  totalCost    Float
  supplierName String
  supplierPhone String  @default("")
  notes        String   @default("")
  currency     String   @default("INR")
  invoiceNumber String  @default("")
  date         DateTime @default(now())
  createdAt    DateTime @default(now())
  supplier Supplier? @relation(fields: [supplierId], references: [id])
  supplierId String?
  @@index([ownerId])
  @@index([ownerId, date])
  @@index([partId])
  @@index([shopId])
}

model StockLog {
  id           String   @id @default(cuid())
  ownerId      String   @default("")
  shopId       String?
  shop         Shop?    @relation(fields: [shopId], references: [id])
  partId       String
  part         SparePart @relation(fields: [partId], references: [id])
  type         String
  quantity     Int
  previousStock Int
  newStock     Int
  referenceId  String   @default("")
  notes        String   @default("")
  date         DateTime @default(now())
  createdAt    DateTime @default(now())
  @@index([ownerId])
  @@index([partId])
  @@index([shopId])
}

model ActivityLog {
  id          String   @id @default(cuid())
  ownerId     String   @default("")
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  action      String
  entityType  String
  entityId    String   @default("")
  summary     String   @default("")
  metadata    String   @default("{}")
  ipAddress   String   @default("")
  createdAt   DateTime @default(now())
  logHash     String?
  @@index([ownerId])
  @@index([userId])
}

model AppSetting {
  id        String   @id @default(cuid())
  ownerId   String   @default("")
  key       String
  value     String
  updatedAt DateTime @updatedAt
  @@unique([ownerId, key])
  @@index([ownerId])
}

model PasswordReset {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  @@index([email])
  @@index([token])
}

model PurchaseOrder {
  id            String   @id @default(cuid())
  ownerId       String   @default("")
  shopId        String?
  shop          Shop?    @relation(fields: [shopId], references: [id])
  poNumber      String   @unique
  supplierId    String?
  supplier      Supplier? @relation(fields: [supplierId], references: [id])
  status        String   @default("draft")
  draftedAt     DateTime @default(now())
  approvedAt    DateTime?
  approvedById  String?
  receivedAt    DateTime?
  receivedById  String?
  cancelledAt   DateTime?
  totalAmount   Float    @default(0)
  currency      String   @default("INR")
  notes         String   @default("")
  lineItems     String   @default("[]")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  batches       Batch[]
  @@index([ownerId])
  @@index([shopId])
  @@index([supplierId])
  @@index([status])
}

model StockTransfer {
  id            String   @id @default(cuid())
  ownerId       String   @default("")
  transferNumber String  @unique
  fromShopId    String
  fromShop      Shop     @relation("StockTransfer_FromShop", fields: [fromShopId], references: [id])
  toShopId      String
  toShop        Shop     @relation("StockTransfer_ToShop", fields: [toShopId], references: [id])
  partId        String
  part          SparePart @relation("StockTransfer_FromPart", fields: [partId], references: [id])
  toPartId      String?
  toPart        SparePart? @relation("StockTransfer_ToPart", fields: [toPartId], references: [id])
  quantity      Int
  status        String   @default("pending")
  shippedAt     DateTime?
  receivedAt    DateTime?
  notes         String   @default("")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  @@index([ownerId])
  @@index([fromShopId])
  @@index([toShopId])
  @@index([partId])
  @@index([status])
}

model PartAlternative {
  id           String   @id @default(cuid())
  ownerId      String   @default("")
  partId       String
  part         SparePart @relation("PartAlternative_From", fields: [partId], references: [id])
  alternativePartId String
  alternativePart   SparePart @relation("PartAlternative_To", fields: [alternativePartId], references: [id])
  reason       String   @default("")
  createdAt    DateTime @default(now())
  @@unique([partId, alternativePartId])
  @@index([ownerId])
  @@index([partId])
  @@index([alternativePartId])
}

model HsnCode {
  id          String   @id @default(cuid())
  code        String   @unique
  description String   @default("")
  rate        Float    @default(0)
  category    String   @default("")
  createdAt   DateTime @default(now())
  @@index([code])
  @@index([category])
  @@index([rate])
}

model CategoryField {
  id          String   @id @default(cuid())
  ownerId     String   @default("")
  category    String
  fieldName   String
  fieldType   String   @default("text")
  fieldOptions String  @default("[]")
  isRequired  Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  values      PartMeta[]
  @@unique([ownerId, category, fieldName])
  @@index([ownerId])
  @@index([category])
}

model PartMeta {
  id              String   @id @default(cuid())
  ownerId         String   @default("")
  partId          String
  part            SparePart @relation(fields: [partId], references: [id], onDelete: Cascade)
  categoryFieldId String
  categoryField   CategoryField @relation(fields: [categoryFieldId], references: [id], onDelete: Cascade)
  value           String   @default("")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  @@unique([partId, categoryFieldId])
  @@index([ownerId])
  @@index([partId])
}

model StockCount {
  id           String   @id @default(cuid())
  ownerId      String   @default("")
  shopId       String?
  countNumber  String   @unique
  status       String   @default("draft")
  startedAt    DateTime @default(now())
  finalizedAt  DateTime?
  finalizedById String?
  notes        String   @default("")
  totalItems   Int      @default(0)
  matchedItems Int      @default(0)
  varianceItems Int     @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  items        StockCountItem[]
  @@index([ownerId])
  @@index([shopId])
  @@index([status])
}

model StockCountItem {
  id            String   @id @default(cuid())
  stockCountId  String
  stockCount    StockCount @relation(fields: [stockCountId], references: [id], onDelete: Cascade)
  partId        String
  part          SparePart @relation(fields: [partId], references: [id])
  expectedQty   Int      @default(0)
  countedQty    Int?
  variance      Int      @default(0)
  notes         String   @default("")
  countedAt     DateTime?
  createdAt     DateTime @default(now())
  @@unique([stockCountId, partId])
  @@index([stockCountId])
  @@index([partId])
}

model SaleReturn {
  id              String   @id @default(cuid())
  ownerId         String   @default("")
  saleId          String
  sale            Sale     @relation(fields: [saleId], references: [id])
  returnNumber    String   @unique
  quantity        Int
  refundAmount    Float     @default(0)
  reason          String   @default("")
  condition       String   @default("resellable")
  restocked       Boolean  @default(true)
  notes           String   @default("")
  processedById   String?
  date            DateTime @default(now())
  createdAt       DateTime @default(now())
  @@index([ownerId])
  @@index([saleId])
  @@index([date])
}

model StockReservation {
  id          String    @id @default(cuid())
  ownerId     String    @default("")
  partId      String
  part        SparePart  @relation(fields: [partId], references: [id])
  quantity    Int
  reservedBy  String    @default("")
  reason      String    @default("")
  expiresAt   DateTime
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  @@index([ownerId])
  @@index([partId])
  @@index([isActive])
  @@index([expiresAt])
}
